generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String   @id @default(uuid()) @db.Uuid
  name           String   @db.VarChar(100)
  email          String   @unique @db.VarChar(255)
  passwordHash   String   @map("password_hash") @db.Text
  role           String   @default("member") @db.VarChar(20)
  linuxUser      String?  @unique @map("linux_user") @db.VarChar(50)
  authMode       String   @default("subscription") @map("auth_mode") @db.VarChar(20)
  claudeAccount  String?  @map("claude_account") @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  // 알림 설정
  phone          String?  @db.VarChar(20)
  notifySms      Boolean  @default(false) @map("notify_sms")
  notifyBrowser  Boolean  @default(true)  @map("notify_browser")
  notifySound    Boolean  @default(true)  @map("notify_sound")

  sessions         Session[]       @relation("CreatedSessions")
  lockedSessions   Session[]       @relation("LockedSessions")
  messages         Message[]
  usageLogs        UsageLog[]
  projectMembers   ProjectMember[]
  notifications    Notification[]
  triggeredCommits Commit[]        @relation("TriggeredCommits")
  // 골드셋 플랫폼
  createdRounds    AssignmentRound[]    @relation("CreatedRounds")
  responses        AssignmentResponse[]

  @@map("users")
}

model UserSession {
  sid    String   @id @db.VarChar(255)
  sess   Json
  expire DateTime @db.Timestamp(6)

  @@index([expire])
  @@map("user_sessions")
}

model Project {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(200)
  repoPath    String   @unique @map("repo_path") @db.VarChar(500)
  description String?  @db.Text
  isAdminOnly Boolean  @default(false) @map("is_admin_only")
  createdAt   DateTime @default(now()) @map("created_at")

  folders        Folder[]
  sessions       Session[]       // 프로젝트 직속 세션 (폴더 미소속)
  commits        Commit[]
  projectMembers ProjectMember[]

  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      String   @default("member") @db.VarChar(20)
  joinedAt  DateTime @default(now()) @map("joined_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model Folder {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  name        String   @db.VarChar(200)
  dirName     String?  @map("dir_name") @db.VarChar(200)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@unique([projectId, name])
  @@index([projectId])
  @@map("folders")
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  projectId        String    @map("project_id") @db.Uuid
  folderId         String?   @map("folder_id") @db.Uuid
  claudeSessionId  String?   @map("claude_session_id") @db.VarChar(100)
  title            String    @db.VarChar(300)
  lockedBy         String?   @map("locked_by") @db.Uuid
  lockedAt         DateTime? @map("locked_at")
  lastActivityAt   DateTime? @map("last_activity_at")
  createdBy        String?   @map("created_by") @db.Uuid
  status           String    @default("active") @db.VarChar(20)
  worktreePath     String?   @map("worktree_path") @db.VarChar(500)
  branchName       String?   @map("branch_name") @db.VarChar(200)
  mergeStatus      String    @default("working") @map("merge_status") @db.VarChar(20)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder    Folder?    @relation(fields: [folderId], references: [id], onDelete: Cascade)
  creator   User?      @relation("CreatedSessions", fields: [createdBy], references: [id], onDelete: SetNull)
  locker    User?      @relation("LockedSessions", fields: [lockedBy], references: [id], onDelete: SetNull)
  messages  Message[]
  commits   Commit[]
  usageLogs UsageLog[]

  @@index([projectId])
  @@index([folderId])
  @@index([folderId, status])
  @@index([lockedBy])
  @@index([claudeSessionId])
  @@map("sessions")
}

model Message {
  id         String   @id @default(uuid()) @db.Uuid
  sessionId  String   @map("session_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  role       String   @db.VarChar(20)
  type       String   @default("text") @db.VarChar(30)
  content    String   @db.Text
  metadata   Json?    @db.JsonB
  tokenCount Int?     @map("token_count")
  createdAt  DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([sessionId, createdAt])
  @@map("messages")
}

model Commit {
  id           String   @id @default(uuid()) @db.Uuid
  sessionId    String?  @map("session_id") @db.Uuid
  projectId    String   @map("project_id") @db.Uuid
  hash         String   @db.VarChar(40)
  message      String?  @db.Text
  author       String?  @db.VarChar(100)
  triggeredBy  String?  @map("triggered_by") @db.Uuid
  filesChanged Json?    @map("files_changed") @db.JsonB
  additions    Int?     @map("additions")
  deletions    Int?     @map("deletions")
  createdAt    DateTime @default(now()) @map("created_at")

  session   Session? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  triggerer User?    @relation("TriggeredCommits", fields: [triggeredBy], references: [id], onDelete: SetNull)

  @@unique([projectId, hash])
  @@index([projectId, createdAt])
  @@index([projectId, author])
  @@index([sessionId])
  @@map("commits")
}

model UsageLog {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  sessionId    String?  @map("session_id") @db.Uuid
  durationMs   Int?     @map("duration_ms")
  inputTokens  Int?     @map("input_tokens")
  outputTokens Int?     @map("output_tokens")
  costUsd      Decimal? @map("cost_usd") @db.Decimal(10, 6)
  createdAt    DateTime @default(now()) @map("created_at")

  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  session Session? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("usage_logs")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar(50)
  payload   Json?    @db.JsonB
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model AudioAsset {
  id          String   @id @default(uuid()) @db.Uuid
  fileName    String   @map("file_name") @db.VarChar(500)
  s3Key       String   @unique @map("s3_key") @db.VarChar(500)
  majorId     Int      @map("major_id")
  midId       Int      @map("mid_id")
  subId       Int?     @map("sub_id")
  mood        String[] @default([])
  tags        String[] @default([])
  description String   @db.Text
  bpm         Int?
  instruments String[] @default([])
  duration    Float?
  format      String   @db.VarChar(20)
  fileSize    Int      @map("file_size")
  embedding   Unsupported("vector(3072)")?
  createdAt   DateTime @default(now()) @map("created_at")

  major CategoryMajor @relation(fields: [majorId], references: [id])
  mid   CategoryMid   @relation(fields: [midId], references: [id])
  sub   CategorySub?  @relation(fields: [subId], references: [id])

  assignmentItems AssignmentItem[]
  goldSet         GoldSet?

  @@index([majorId])
  @@index([majorId, midId])
  @@index([majorId, midId, subId])
  @@map("audio_assets")
}

// ───────────────────────────────────────────
// 카테고리 마스터 (정규화된 분류 체계)
// ───────────────────────────────────────────
model CategoryMajor {
  id    Int    @id @default(autoincrement())
  key   String @unique @db.VarChar(50)
  label String @db.VarChar(100)

  mids       CategoryMid[]
  audioAssets AudioAsset[]
  responses  AssignmentResponse[]
  agreedItems AssignmentItem[]    @relation("ItemAgreedMajor")
  goldSet    GoldSet[]

  @@map("category_major")
}

model CategoryMid {
  id      Int    @id @default(autoincrement())
  majorId Int    @map("major_id")
  key     String @db.VarChar(50)

  major       CategoryMajor @relation(fields: [majorId], references: [id], onDelete: Cascade)
  subs        CategorySub[]
  audioAssets AudioAsset[]
  responses   AssignmentResponse[]
  agreedItems AssignmentItem[]   @relation("ItemAgreedMid")
  goldSet     GoldSet[]

  @@unique([majorId, key])
  @@index([majorId])
  @@map("category_mid")
}

model CategorySub {
  id    Int    @id @default(autoincrement())
  midId Int    @map("mid_id")
  key   String @db.VarChar(50)

  mid         CategoryMid @relation(fields: [midId], references: [id], onDelete: Cascade)
  audioAssets AudioAsset[]
  responses   AssignmentResponse[]
  agreedItems AssignmentItem[]   @relation("ItemAgreedSub")
  goldSet     GoldSet[]

  @@unique([midId, key])
  @@index([midId])
  @@map("category_sub")
}

// ───────────────────────────────────────────
// 골드셋 수집 플랫폼 (라운드 / 응답 / 골드셋)
// ───────────────────────────────────────────
model AssignmentRound {
  id          String   @id @default(uuid()) @db.Uuid
  title       String   @db.VarChar(200)
  createdBy   String   @map("created_by") @db.Uuid
  status      String   @default("open") @db.VarChar(20) // open | closed
  itemCount   Int      @map("item_count")
  createdAt   DateTime @default(now()) @map("created_at")
  closedAt    DateTime? @map("closed_at")

  creator User              @relation("CreatedRounds", fields: [createdBy], references: [id], onDelete: Cascade)
  items   AssignmentItem[]
  goldSet GoldSet[]

  @@index([status, createdAt])
  @@map("assignment_round")
}

model AssignmentItem {
  id             String   @id @default(uuid()) @db.Uuid
  roundId        String   @map("round_id") @db.Uuid
  audioAssetId   String   @map("audio_asset_id") @db.Uuid
  status         String   @default("pending") @db.VarChar(20) // pending | agreed | disagreed
  agreedMajorId  Int?     @map("agreed_major_id")
  agreedMidId    Int?     @map("agreed_mid_id")
  agreedSubId    Int?     @map("agreed_sub_id")
  responseCount  Int      @default(0) @map("response_count")

  round       AssignmentRound      @relation(fields: [roundId], references: [id], onDelete: Cascade)
  audioAsset  AudioAsset           @relation(fields: [audioAssetId], references: [id], onDelete: Cascade)
  responses   AssignmentResponse[]
  agreedMajor CategoryMajor?       @relation("ItemAgreedMajor", fields: [agreedMajorId], references: [id])
  agreedMid   CategoryMid?         @relation("ItemAgreedMid", fields: [agreedMidId], references: [id])
  agreedSub   CategorySub?         @relation("ItemAgreedSub", fields: [agreedSubId], references: [id])

  @@unique([roundId, audioAssetId])
  @@index([roundId, status])
  @@map("assignment_item")
}

model AssignmentResponse {
  id          String   @id @default(uuid()) @db.Uuid
  itemId      String   @map("item_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  majorId     Int      @map("major_id")
  midId       Int      @map("mid_id")
  subId       Int?     @map("sub_id")
  respondedAt DateTime @default(now()) @map("responded_at")

  item  AssignmentItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  major CategoryMajor  @relation(fields: [majorId], references: [id])
  mid   CategoryMid    @relation(fields: [midId], references: [id])
  sub   CategorySub?   @relation(fields: [subId], references: [id])

  @@unique([itemId, userId])
  @@index([userId])
  @@map("assignment_response")
}

model GoldSet {
  id            String   @id @default(uuid()) @db.Uuid
  audioAssetId  String   @unique @map("audio_asset_id") @db.Uuid
  majorId       Int      @map("major_id")
  midId         Int      @map("mid_id")
  subId         Int?     @map("sub_id")
  roundId       String?  @map("round_id") @db.Uuid
  agreedBy      String[] @map("agreed_by") @db.Uuid
  confirmedAt   DateTime @default(now()) @map("confirmed_at")

  audioAsset AudioAsset       @relation(fields: [audioAssetId], references: [id], onDelete: Cascade)
  major      CategoryMajor    @relation(fields: [majorId], references: [id])
  mid        CategoryMid      @relation(fields: [midId], references: [id])
  sub        CategorySub?     @relation(fields: [subId], references: [id])
  round      AssignmentRound? @relation(fields: [roundId], references: [id], onDelete: SetNull)

  @@index([majorId, midId])
  @@index([confirmedAt])
  @@map("gold_set")
}
