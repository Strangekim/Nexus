# ============================================================
# Nexus 백엔드 환경변수 예시
# 이 파일을 복사하여 .env 로 저장하고 실제 값을 채워넣는다.
# cp backend/.env.example backend/.env
# ============================================================

# ────────────────────────────────────────
# [필수] 데이터베이스
# PostgreSQL 연결 문자열 — Prisma ORM에서 사용
# 형식: postgresql://{유저}:{비밀번호}@{호스트}:{포트}/{DB명}
# ────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ────────────────────────────────────────
# [필수] 세션 보안
# httpOnly 쿠키 세션 암호화에 사용되는 시크릿 키
# 최소 32자 이상의 무작위 문자열 권장 (예: openssl rand -hex 32)
# 절대 코드에 하드코딩하거나 Git에 커밋하지 않는다
# ────────────────────────────────────────
SESSION_SECRET=change-this-to-a-random-secret

# ────────────────────────────────────────
# [선택] 서버 설정
# ────────────────────────────────────────
# Fastify 서버 포트 (기본값: 8080)
PORT=8080

# 실행 환경 — 'development' | 'production'
# production이면 SMS 실제 발송, development이면 SMS 테스트 모드(testmode_yn=Y)
NODE_ENV=development

# 프론트엔드 URL — CORS 허용 출처 설정에 사용
FRONTEND_URL=http://localhost:3000

# ────────────────────────────────────────
# [필수] Claude OAuth 인증 디렉토리
# 팀원별 Claude OAuth 자격증명(credentials.json)과 JSONL 세션 파일이 저장되는 루트 디렉토리
# 각 사용자 디렉토리는 {CLAUDE_CONFIGS_DIR}/{userId}/ 형식으로 생성됨
# 디렉토리 권한: 700 (소유자만 접근), credentials.json 파일 권한: 600
# 예: mkdir -p /home/ubuntu/claude-configs && chmod 700 /home/ubuntu/claude-configs
# ────────────────────────────────────────
CLAUDE_CONFIGS_DIR=/home/ubuntu/claude-configs

# ────────────────────────────────────────
# [선택] 알리고 SMS API
# 세 값이 모두 설정된 경우에만 SMS 발송 활성화됨.
# 미설정 시 SMS 기능은 자동으로 비활성화되며 서버 시작에는 영향 없음.
# 알리고 회원가입 후 API 키 발급: https://smartsms.aligo.in/
# ────────────────────────────────────────
# 알리고 API 키 (알리고 계정 > API 설정에서 확인)
ALIGO_API_KEY=your_aligo_api_key

# 알리고 계정 ID (로그인 아이디)
ALIGO_USER_ID=your_aligo_user_id

# SMS 발신 번호 (알리고에 등록된 발신 번호, 형식: 01012345678)
ALIGO_SENDER=01012345678
