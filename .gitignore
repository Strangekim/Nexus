# 루트 수준 gitignore — 프로젝트 전체 공통 규칙

# 환경변수 파일 — 절대 커밋 금지 (.example 파일은 허용)
.env
.env.local
.env.production
.env.production.local
.env.staging
.env.test
.env.test.local
!*.env.example
!**/.env.example

# 의존성
node_modules/
**/node_modules/

# 빌드 산출물
dist/
build/
.next/
out/

# 로그
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS 메타데이터
.DS_Store
Thumbs.db

# IDE 설정
.vscode/
.idea/
*.swp

# TypeScript 캐시
*.tsbuildinfo

# 패키지 락 파일 (선택적 추적 — 팀 정책에 따라)
# package-lock.json

# Prisma 생성 파일
backend/src/generated/
.claude/
.playwright-mcp/
