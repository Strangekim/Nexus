# 루트 수준 gitignore — 프로젝트 전체 공통 규칙

# 환경변수 파일 — 절대 커밋 금지 (.example 파일은 허용)
.env
.env.local
.env.production
.env.production.local
.env.staging
.env.test
.env.test.local
!*.env.example
!**/.env.example

# 의존성
node_modules/
**/node_modules/

# 빌드 산출물
dist/
build/
.next/
out/

# 로그
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS 메타데이터
.DS_Store
Thumbs.db

# IDE 설정
.vscode/
.idea/
*.swp

# TypeScript 캐시
*.tsbuildinfo

# Prisma 생성 파일
backend/src/generated/
.claude/
.playwright-mcp/

# Playwright 테스트 아티팩트
/test-results/
/playwright-report/
/*.png
/*.jpg
/*.jpeg

# Python 캐시 / 가상환경
__pycache__/
**/__pycache__/
**/venv/
*.pyc

# 인증서 / 키 파일
*.pem
*.key
*.p12
*.pfx

# 스크린샷 캡처 스크립트 (크레덴셜 포함)
tools/screenshot.mjs
tools/crop-screenshots.mjs

# 배포 스크립트 (서버 경로 포함)
deploy-*.sh

# 파이프라인 중간 결과
tools/audio-pipeline/manifest/*.jsonl
tools/audio-pipeline/.env
