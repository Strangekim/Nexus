# ============================================================
# Nexus Docker 환경변수 설정
# 이 파일을 .env로 복사한 뒤 값을 수정하여 사용
# cp .env.docker.example .env
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=nexus
POSTGRES_USER=nexus
POSTGRES_PASSWORD=changeme_secure_password
POSTGRES_PORT=5432

# --- Backend ---
# 세션 시크릿 (반드시 변경)
SESSION_SECRET=changeme_random_secret_at_least_32_chars

# 외부 노출 포트
BACKEND_PORT=8080

# 프론트엔드 URL (CORS 허용 origin)
FRONTEND_URL=http://localhost:3000

# --- Frontend ---
# API 서버 URL (브라우저에서 접근하는 주소)
NEXT_PUBLIC_API_URL=http://localhost:8080

# 외부 노출 포트
FRONTEND_PORT=3000

# AES-256-GCM 암호화 키 — node -e "console.log(require(\"crypto\").randomBytes(32).toString(\"hex\"))" 로 생성
ENCRYPTION_KEY=
