# ============================================================
# Nexus 프론트엔드 환경변수 예시 (Next.js)
# 이 파일을 복사하여 .env.local 로 저장하고 실제 값을 채워넣는다.
# cp frontend/.env.local.example frontend/.env.local
#
# NEXT_PUBLIC_ 접두사가 붙은 변수는 브라우저에 노출된다.
# 민감한 값(API 키, 시크릿 등)은 NEXT_PUBLIC_ 없이 서버 전용으로 사용한다.
# ============================================================

# ────────────────────────────────────────
# [필수] 백엔드 API 서버 URL
# 프론트엔드에서 fetch 호출 시 사용하는 백엔드 기본 URL.
# NEXT_PUBLIC_ 접두사로 브라우저에서 접근 가능하다.
#
# 로컬 개발: http://localhost:8080
# EC2 배포:  http://{EC2_PUBLIC_IP}:8080 또는 https://api.nexus.example.com
# ────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
